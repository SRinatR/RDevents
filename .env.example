# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://event_platform_user:event_platform_password@localhost:5432/event_platform?schema=public"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change_me_access_secret_min_32_chars"
JWT_REFRESH_SECRET="change_me_refresh_secret_min_32_chars"
# Access token TTL in seconds (default 15 minutes)
JWT_ACCESS_TTL=900
# Refresh token TTL in seconds (default 7 days)
JWT_REFRESH_TTL=604800

# ─── API ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=4000
CORS_ORIGIN="http://localhost:3000"

# ─── Web ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"

# ─── Social Auth (optional — dev mocks work without these) ───────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:4000/api/auth/google/callback"

YANDEX_CLIENT_ID=""
YANDEX_CLIENT_SECRET=""
YANDEX_REDIRECT_URI="http://localhost:4000/api/auth/yandex/callback"

TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
