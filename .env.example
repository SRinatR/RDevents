# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=event_platform
POSTGRES_USER=event_platform_user
POSTGRES_PASSWORD=event_platform_password
DATABASE_URL="postgresql://event_platform_user:event_platform_password@localhost:5432/event_platform?schema=public"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change_me_access_secret_min_32_chars"
JWT_REFRESH_SECRET="change_me_refresh_secret_min_32_chars"
# Access token TTL in seconds (default 15 minutes)
JWT_ACCESS_TTL=900
# Refresh token TTL in seconds (default 7 days)
JWT_REFRESH_TTL=604800
# Registration email code TTL in seconds (default 6 minutes)
REGISTRATION_CODE_TTL=360
# Time allowed to finish password setup after code verification
REGISTRATION_COMPLETION_TTL=1800
# Maximum wrong code attempts before a new code is required
REGISTRATION_MAX_ATTEMPTS=5
# Minimum seconds between repeated code sends
REGISTRATION_RESEND_COOLDOWN=60

# ─── API ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=4000
CORS_ORIGIN="http://localhost:3000"
RESEND_API_KEY=""
RESEND_FROM_EMAIL="auth@rdevents.uz"
RESEND_FROM_NAME="RDEvents"
# Set only if this mailbox exists and is monitored
RESEND_REPLY_TO_EMAIL=""
# Resend/Svix webhook verification secret from the Resend webhook settings.
RESEND_WEBHOOK_SECRET=""
RESEND_WEBHOOK_ENDPOINT="https://api.rdevents.uz/webhooks/resend"
# Use log-only locally so admin test/direct emails work without external delivery.
# Production ignores log-only mode and requires RESEND_API_KEY + RESEND_FROM_EMAIL.
EMAIL_PROVIDER="log-only"
EMAIL_BROADCAST_MAX_RECIPIENTS=5000
EMAIL_BROADCAST_BATCH_SIZE=50
EMAIL_BROADCAST_CONCURRENCY=3
EMAIL_BROADCAST_BATCH_DELAY_MS=1000
EMAIL_TEST_SEND_RATE_LIMIT_PER_HOUR=20

# ─── Media Storage ────────────────────────────────────────────────────────────
MEDIA_STORAGE_DRIVER=local
MEDIA_UPLOAD_DIR=./uploads
MEDIA_PUBLIC_BASE_URL=http://localhost:4000/uploads
# Production example:
# MEDIA_PUBLIC_BASE_URL=https://api.rdevents.uz/uploads
MAX_AVATAR_UPLOAD_MB=3
MAX_DOCUMENT_UPLOAD_MB=10

# ─── RBAC v2 rollout flags ───────────────────────────────────────────────────
RBAC_V2_ENABLED=false
RBAC_V2_LEGACY_FALLBACK=true
RBAC_V2_DUAL_WRITE=false
RBAC_V2_SHADOW_COMPARE=false

# ─── Web ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"

# ─── Social Auth (optional — dev mocks work without these) ───────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:4000/api/auth/google/callback"

YANDEX_CLIENT_ID=""
YANDEX_CLIENT_SECRET=""
YANDEX_REDIRECT_URI="http://localhost:4000/api/auth/yandex/callback"

TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
