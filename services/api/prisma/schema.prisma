  INITIAL_APPROVAL
  MEMBER_REPLACEMENT
  MEMBER_ADD
  MEMBER_REMOVE
  CAPTAIN_TRANSFER
  DETAILS_UPDATE
  WITHDRAWAL_REQUEST
  ADMIN_CORRECTION
