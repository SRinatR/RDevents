model EmailBroadcastEvent {
  id          String                  @id @default(cuid())
  broadcastId String
  recipientId String?
  type        EmailBroadcastEventType
  actorUserId String?
  payloadJson Json?
  createdAt   DateTime                @default(now())

  broadcast EmailBroadcast           @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  recipient EmailBroadcastRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)
  actor     User?                    @relation("EmailBroadcastEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([broadcastId])
  @@index([recipientId])
  @@index([type])
  @@index([createdAt])
  @@map("email_broadcast_events")
}

model EmailAudience {
  id          String              @id @default(cuid())
  name        String
  description String?
  source      EmailAudienceSource
  filterJson  Json
  isSystem    Boolean             @default(false)
  isActive    Boolean             @default(true)
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  createdBy  User?            @relation("EmailAudienceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  broadcasts EmailBroadcast[]

  @@index([source])
  @@index([isActive])
  @@map("email_audiences")
}

model EmailWebhookEvent {
  id                String                       @id @default(cuid())
  eventType         String
  providerEventId   String?                      @unique
  providerMessageId String?
  payloadJson       Json
  processingStatus  EmailWebhookProcessingStatus @default(PENDING)
  relatedMessageId  String?
  errorMessage      String?                      @db.Text
  receivedAt        DateTime                     @default(now())
  processedAt       DateTime?

  relatedMessage EmailMessage? @relation(fields: [relatedMessageId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([providerMessageId])
  @@index([processingStatus])
  @@index([receivedAt])
  @@map("email_webhook_events")
}

// ─── System Report Module ────────────────────────────────────────────────────

model SystemReportTemplate {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  isDefault   Boolean  @default(false)
  configJson  Json // Full report configuration
  createdById String
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User              @relation("SystemReportTemplateCreatedBy", fields: [createdById], references: [id])
  runs      SystemReportRun[]

  @@index([createdById])
  @@index([slug])
  @@map("system_report_templates")
}

model SystemReportRun {
  id                String    @id @default(cuid())
  templateId        String?
  title             String?
  status            String    @default("queued") // queued, running, success, failed, partial_success, canceled, stale
  stage             String? // queued, collecting, assembling, writing_artifacts, finalizing
  progressPercent   Int       @default(0) // 0-100
  configJson        Json // Report configuration used
  summaryJson       Json? // Computed summary
  errorText         String?
  requestedByUserId String
  requestedByEmail  String
  startedAt         DateTime?
  finishedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  template    SystemReportTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  requestedBy User                   @relation("SystemReportRunRequestedBy", fields: [requestedByUserId], references: [id])
  artifacts   SystemReportArtifact[]
  events      SystemReportEvent[]

  @@index([templateId])
  @@index([requestedByUserId])
  @@index([status])
  @@index([createdAt])
  @@map("system_report_runs")
}

model SystemReportArtifact {
  id          String   @id @default(cuid())
  runId       String
  kind        String // report, attachment, log, metadata
  fileName    String
  mimeType    String
  storagePath String
  sizeBytes   Int
  checksum    String?
  createdAt   DateTime @default(now())

  run SystemReportRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("system_report_artifacts")
}

model SystemReportEvent {
  id          String   @id @default(cuid())
  runId       String
  level       String // info, warning, error
  code        String
  message     String
  payloadJson Json?
  createdAt   DateTime @default(now())

  run SystemReportRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([level])
  @@index([createdAt])
  @@map("system_report_events")
}

model AuditLog {
  id String @id @default(cuid())

  actorUserId String?
  action      AuditAction

  workspaceId  String?
  eventId      String?
  targetUserId String?

  beforeJson Json?
  afterJson  Json?
  meta       Json?

  requestId String?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  actor      User? @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUser User? @relation("AuditLogTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([workspaceId])
  @@index([eventId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
