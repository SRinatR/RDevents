// Prisma schema for Event Platform MVP
// Single PostgreSQL database. Platform roles stay on User; event roles live in EventMember.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  PLATFORM_ADMIN
  SUPER_ADMIN
}

enum AuthProvider {
  EMAIL
  GOOGLE
  YANDEX
  TELEGRAM
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum EventMemberRole {
  PARTICIPANT
  VOLUNTEER
  EVENT_ADMIN
}

enum EventMemberStatus {
  PENDING
  ACTIVE
  RESERVE
  REJECTED
  CANCELLED
  REMOVED
}

enum TeamJoinMode {
  OPEN
  BY_CODE
  BY_REQUEST
}

enum RegistrationMode {
  INDIVIDUAL
  TEAM
  BOTH
}

enum EventTeamStatus {
  ACTIVE
  PENDING
  REJECTED
  ARCHIVED
}

enum EventTeamRole {
  CAPTAIN
  MEMBER
}

enum EventTeamMemberStatus {
  PENDING
  ACTIVE
  REJECTED
  REMOVED
  LEFT
}

enum AnalyticsEventType {
  HOME_VIEW
  EVENTS_LIST_VIEW
  EVENT_DETAIL_VIEW
  REGISTER_CLICK
  EVENT_REGISTRATION
  USER_REGISTER
  USER_LOGIN
  PROVIDER_USED
  TEAM_CREATED
  TEAM_JOIN_REQUESTED
  TEAM_MEMBER_APPROVED
  VOLUNTEER_APPLICATION_SUBMITTED
  VOLUNTEER_APPLICATION_APPROVED
  VOLUNTEER_APPLICATION_REJECTED
  EVENT_ADMIN_ASSIGNED
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String?
  // Name fields
  lastNameCyrillic   String?
  firstNameCyrillic  String?
  middleNameCyrillic String?
  lastNameLatin      String?
  firstNameLatin     String?
  middleNameLatin    String?
  fullNameCyrillic   String?
  fullNameLatin      String?
  
  bio             String?
  city            String?
  phone           String?
  telegram        String?
  birthDate       DateTime?
  avatarUrl       String?
  role            UserRole  @default(USER)
  isActive        Boolean   @default(true)
  emailVerifiedAt DateTime?
  registeredAt    DateTime  @default(now())
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts             UserAccount[]
  createdEvents        Event[]           @relation("CreatedBy")
  eventMemberships     EventMember[]     @relation("EventMemberUser")
  assignedEventMembers EventMember[]     @relation("EventMemberAssignedBy")
  teamMemberships      EventTeamMember[]
  captainedTeams       EventTeam[]       @relation("TeamCaptain")
  analyticsEvents      AnalyticsEvent[]
  registrationSubmissions EventRegistrationFormSubmission[]

  @@map("users")
}

model UserAccount {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  providerEmail     String?
  providerUsername  String?
  providerAvatarUrl String?
  linkedAt          DateTime     @default(now())
  lastUsedAt        DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("user_accounts")
}

model Event {
  id                   String      @id @default(cuid())
  slug                 String      @unique
  title                String
  shortDescription     String
  fullDescription      String      @db.Text
  coverImageUrl        String?
  category             String
  location             String
  
  // Registration and limits
  capacity             Int         @default(100)
  registrationsCount   Int         @default(0)
  
  // Timing
  startsAt             DateTime
  endsAt               DateTime
  registrationOpenAt   DateTime?
  registrationCloseAt  DateTime?
  
  // Registration Settings
  registrationEnabled          Boolean @default(true)
  registrationMode             RegistrationMode @default(INDIVIDUAL)
  volunteerApplicationsEnabled Boolean @default(false)
  requiredProfileFields        String[] @default([])
  requiredEventFields          String[] @default([])
  customRegistrationFields     Json?

  conditions           String?
  contactEmail         String?
  tags                 String[]
  status               EventStatus @default(DRAFT)
  isFeatured           Boolean     @default(false)

  // Team settings
  isTeamBased                  Boolean      @default(false)
  minTeamSize                  Int          @default(1)
  maxTeamSize                  Int          @default(1)
  allowSoloParticipation       Boolean      @default(true)
  teamJoinMode                 TeamJoinMode @default(OPEN)
  requireAdminApprovalForTeams Boolean      @default(false)

  publishedAt DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy       User?            @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  members         EventMember[]
  teams           EventTeam[]
  analyticsEvents AnalyticsEvent[]
  registrationSubmissions EventRegistrationFormSubmission[]

  @@map("events")
}

model EventRegistrationFormSubmission {
  id            String   @id @default(cuid())
  eventId       String
  userId        String
  answersJson   Json
  isComplete    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
  @@map("event_registration_form_submissions")
}

model EventMember {
  id               String            @id @default(cuid())
  eventId          String
  userId           String
  role             EventMemberRole
  status           EventMemberStatus @default(PENDING)
  assignedByUserId String?
  assignedAt       DateTime          @default(now())
  approvedAt       DateTime?
  rejectedAt       DateTime?
  cancelledAt      DateTime?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  event          Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User  @relation("EventMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedByUser User? @relation("EventMemberAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@unique([eventId, userId, role])
  @@index([userId, role, status])
  @@index([eventId, role, status])
  @@map("event_members")
}

model EventTeam {
  id            String          @id @default(cuid())
  eventId       String
  name          String
  joinCode      String?         @unique
  captainUserId String
  status        EventTeamStatus @default(ACTIVE)
  maxSize       Int             @default(5)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  event       Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  captainUser User              @relation("TeamCaptain", fields: [captainUserId], references: [id], onDelete: Cascade)
  members     EventTeamMember[]

  @@index([eventId])
  @@index([captainUserId])
  @@map("event_teams")
}

model EventTeamMember {
  id         String                @id @default(cuid())
  teamId     String
  userId     String
  role       EventTeamRole         @default(MEMBER)
  status     EventTeamMemberStatus @default(PENDING)
  joinedAt   DateTime              @default(now())
  approvedAt DateTime?
  removedAt  DateTime?

  team EventTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId, status])
  @@index([userId, status])
  @@map("event_team_members")
}

model AnalyticsEvent {
  id           String             @id @default(cuid())
  type         AnalyticsEventType
  userId       String?
  eventId      String?
  authProvider AuthProvider?
  sessionId    String?
  locale       String?
  path         String?
  meta         Json?
  createdAt    DateTime           @default(now())

  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([createdAt])
  @@index([eventId])
  @@map("analytics_events")
}
