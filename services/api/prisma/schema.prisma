// ─── Email Operations ────────────────────────────────────────────────────────

model EmailTemplate {
  id          String              @id @default(cuid())
  name        String
  key         String              @unique
  subject     String
  preheader   String?
  htmlBody    String              @db.Text
  textBody    String              @db.Text
  status      EmailTemplateStatus @default(DRAFT)
  createdById String?
  updatedById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  createdBy  User?            @relation("EmailTemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy  User?            @relation("EmailTemplateUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  broadcasts EmailBroadcast[]
  messages   EmailMessage[]

  @@index([status])
  @@index([createdById])
  @@map("email_templates")
}

model EmailBroadcast {
  id                 String               @id @default(cuid())
  title              String
  type               EmailBroadcastType   @default(MARKETING)
  subject            String
  preheader          String?
  htmlBody           String               @db.Text
  textBody           String               @db.Text
  audienceKind       EmailAudienceKind    @default(MAILING_CONSENT)
  audienceSource     EmailAudienceSource  @default(STATIC_FILTER)
  audienceFilterJson Json?
  savedAudienceId    String?
  status             EmailBroadcastStatus @default(DRAFT)
  sendMode           EmailSendMode        @default(DRAFT)
  scheduledAt        DateTime?
  timezone           String?              @default("Asia/Tashkent")
  startedAt          DateTime?
  finishedAt         DateTime?
  cancelledAt        DateTime?
  totalMatched       Int                  @default(0)
  totalEligible      Int                  @default(0)
  totalSkipped       Int                  @default(0)
  totalRecipients    Int                  @default(0)
  queuedCount        Int                  @default(0)
  sentCount          Int                  @default(0)
  deliveredCount     Int                  @default(0)
  openedCount        Int                  @default(0)
  clickedCount       Int                  @default(0)
  failedCount        Int                  @default(0)
  bouncedCount       Int                  @default(0)
  complainedCount    Int                  @default(0)
  unsubscribedCount  Int                  @default(0)
  errorText          String?              @db.Text
  internalNotes      String?              @db.Text
  templateId         String?
  createdById        String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  template      EmailTemplate?            @relation(fields: [templateId], references: [id], onDelete: SetNull)
  savedAudience EmailAudience?            @relation(fields: [savedAudienceId], references: [id], onDelete: SetNull)
  createdBy     User?                     @relation("EmailBroadcastCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  messages      EmailMessage[]
  recipients    EmailBroadcastRecipient[]
  events        EmailBroadcastEvent[]

  @@index([status])
  @@index([type])
  @@index([audienceKind])
  @@index([audienceSource])
  @@index([scheduledAt])
  @@index([templateId])
  @@index([savedAudienceId])
  @@index([createdById])
  @@index([createdAt])
  @@map("email_broadcasts")
}

model EmailBroadcastRecipient {
  id                    String               @id @default(cuid())
  broadcastId           String
  userId                String?
  email                 String               @db.Citext
  normalizedEmail       String               @db.Citext
  name                  String?
  status                EmailRecipientStatus @default(MATCHED)
  skipReason            String?              @db.Text
  failureReason         String?              @db.Text
  consentSnapshotJson   Json?
  variablesSnapshotJson Json?
  audienceReasonJson    Json?
  emailMessageId        String?
  provider              String?
  providerMessageId     String?
  queuedAt              DateTime?
  sendingAt             DateTime?
  sentAt                DateTime?
  deliveredAt           DateTime?
  openedAt              DateTime?
  clickedAt             DateTime?
  bouncedAt             DateTime?
  complainedAt          DateTime?
  unsubscribedAt        DateTime?
  failedAt              DateTime?
  skippedAt             DateTime?
  cancelledAt           DateTime?
  retryCount            Int                  @default(0)
  lastRetryAt           DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  broadcast    EmailBroadcast        @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  user         User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  emailMessage EmailMessage?         @relation(fields: [emailMessageId], references: [id], onDelete: SetNull)
  events       EmailBroadcastEvent[]

  @@unique([broadcastId, normalizedEmail])
  @@index([broadcastId])
  @@index([status])
  @@index([userId])
  @@index([normalizedEmail])
  @@index([providerMessageId])
  @@map("email_broadcast_recipients")
}

model EmailMessage {
  id                String             @id @default(cuid())
  toEmail           String              @db.Citext
  toUserId          String?
  subject           String
  source            EmailMessageSource
  status            EmailMessageStatus @default(PENDING)
  providerMessageId String?            @unique
  errorText         String?            @db.Text
  sentAt            DateTime?
  deliveredAt       DateTime?
  openedAt          DateTime?
  clickedAt         DateTime?
  bouncedAt         DateTime?
  complainedAt      DateTime?
  broadcastId       String?
  templateId        String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  toUser              User?                     @relation("EmailMessageUser", fields: [toUserId], references: [id], onDelete: SetNull)
  broadcast           EmailBroadcast?           @relation(fields: [broadcastId], references: [id], onDelete: SetNull)
  template            EmailTemplate?            @relation(fields: [templateId], references: [id], onDelete: SetNull)
  webhookEvents       EmailWebhookEvent[]
  broadcastRecipients EmailBroadcastRecipient[]

  @@index([toEmail])
  @@index([toUserId])
  @@index([source])
  @@index([status])
  @@index([sentAt])
  @@index([createdAt])
  @@index([broadcastId])
  @@map("email_messages")
}

model UserCommunicationConsent {
