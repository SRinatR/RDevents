  EVENTS_LIST_VIEW
  EVENT_DETAIL_VIEW
  REGISTER_CLICK
  EVENT_REGISTRATION
  USER_REGISTER
  USER_LOGIN
  PROVIDER_USED
  TEAM_CREATED
  TEAM_JOIN_REQUESTED
  TEAM_MEMBER_APPROVED
  VOLUNTEER_APPLICATION_SUBMITTED
