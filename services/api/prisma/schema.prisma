// Prisma schema for Event Platform MVP
// Single PostgreSQL database. Platform roles stay on User; event roles live in EventMember.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  PLATFORM_ADMIN
  SUPER_ADMIN
}

enum OrganizerWorkspaceKind {
  ROOT_ORGANIZATION
  DEPARTMENT
  SUBDEPARTMENT
  WORKING_GROUP
  EXTERNAL_PARTNER
}

enum OrganizerWorkspaceStatus {
  ACTIVE
  ARCHIVED
  DISABLED
}

enum OrganizerMemberRole {
  OWNER
  ADMIN
  MANAGER
  PR_MANAGER
  CHECKIN_MANAGER
  VIEWER
}

enum OrganizerMemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
}

enum AuthProvider {
  EMAIL
  GOOGLE
  YANDEX
  TELEGRAM
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum EventMemberRole {
  PARTICIPANT
  VOLUNTEER
  EVENT_ADMIN
}

enum EventMemberStatus {
  PENDING
  APPROVED
  ACTIVE
  RESERVE
  REJECTED
  CANCELLED
  REMOVED
}

enum EventStaffRole {
  OWNER
  ADMIN
  MANAGER
  PR_MANAGER
  CHECKIN_OPERATOR
  VIEWER
}

enum EventStaffGrantStatus {
  ACTIVE
  DISABLED
  REMOVED
}

enum EventStaffGrantSource {
  DIRECT
  WORKSPACE_POLICY
  SYSTEM
  LEGACY_EVENT_ADMIN_MIGRATION
}

enum EventStaffAccessStatus {
  ACTIVE
  REMOVED
}

enum WorkspaceEventAccessPolicyStatus {
  ACTIVE
  DISABLED
  REMOVED
}

enum TeamJoinMode {
  OPEN
  BY_CODE
  BY_REQUEST
  EMAIL_INVITE
}

enum RegistrationMode {
  INDIVIDUAL
  TEAM
  BOTH
