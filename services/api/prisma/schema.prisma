  MEMBER_REMOVED
  MEMBER_REPLACED
  MEMBER_WITHDRAWAL_REQUESTED
  CAPTAIN_TRANSFERRED
  TEAM_DETAILS_UPDATED
  ADMIN_TEAM_RENAMED
