  createdBy User?              @relation("WorkspaceEventAccessPolicyCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  revokedBy User?              @relation("WorkspaceEventAccessPolicyRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)

