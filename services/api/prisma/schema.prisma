  SCHOOL_STUDENT
  COLLEGE_STUDENT
  UNIVERSITY_STUDENT
  EMPLOYED
  UNEMPLOYED
}

enum LanguageLevel {
  A1
  A2
  B1
  B2
  C1
  C2
  NATIVE
}

enum ActivityDirection {
  SCIENCE_EDUCATION
  PUBLIC_ADMINISTRATION_LAW
  MEDIA
  CREATIVE_INDUSTRIES
  ENTREPRENEURSHIP
  SPORT_HEALTHCARE
  AGRICULTURE_AGROTECH
  DIGITALIZATION_IT
  TOURISM_HOSPITALITY
  ECOLOGY
  CIVIL_SOCIETY
  ARCHITECTURE_CONSTRUCTION
  ECONOMICS_FINANCE
  INDUSTRY_TECHNOLOGY_ENGINEERING
  OTHER
}

enum AdditionalDocumentType {
  SCHOOL_PROOF
  STUDENT_PROOF
  BIRTH_CERTIFICATE
}

enum SupportThreadStatus {
  OPEN
  IN_PROGRESS
  WAITING_USER
  CLOSED
}

enum SupportSenderType {
  USER
  ADMIN
}

enum MediaAssetPurpose {
  AVATAR
  DOCUMENT
}

enum MediaAssetStatus {
  ACTIVE
  DELETED
}

enum EmailMessageStatus {
  PENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  FAILED
}

enum EmailMessageSource {
  VERIFICATION
  INVITATION
  NOTIFICATION
  BROADCAST
  ADMIN_TEST
  ADMIN_DIRECT
  PASSWORD_RESET
  SYSTEM
}

enum EmailTemplateStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum EmailBroadcastStatus {
  DRAFT
  SCHEDULED
  QUEUED
  SENDING
  SENT
  PARTIAL
  FAILED
  CANCELLED
}

enum EmailAudienceKind {
  MAILING_CONSENT
  VERIFIED_USERS
  ACTIVE_USERS
  PLATFORM_ADMINS
}

enum EmailBroadcastType {
  MARKETING
  EVENT_ANNOUNCEMENT
  EVENT_REMINDER
  SYSTEM_NOTIFICATION
  ADMIN_TEST
  TRANSACTIONAL
}

enum EmailSendMode {
  DRAFT
  SEND_NOW
  SCHEDULED
}

enum EmailRecipientStatus {
  MATCHED
  QUEUED
  SENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  FAILED
  BOUNCED
  COMPLAINED
  SKIPPED_NO_CONSENT
  SKIPPED_NO_EMAIL
  SKIPPED_EMAIL_NOT_VERIFIED
  SKIPPED_UNSUBSCRIBED
  SKIPPED_BLOCKED
  SKIPPED_DUPLICATE_EMAIL
  SKIPPED_SUPPRESSED
  SKIPPED_INVALID_EMAIL
  CANCELLED
}

enum EmailConsentChannel {
  EMAIL
  TELEGRAM
  SMS
  PUSH
}

enum EmailConsentTopic {
  MARKETING
  EVENT_ANNOUNCEMENTS
  EVENT_REMINDERS
  PLATFORM_NEWS
  PARTNER_NEWS
  SYSTEM
}

enum EmailConsentStatus {
  OPTED_IN
  OPTED_OUT
  UNKNOWN
}

enum EmailAudienceSource {
  STATIC_FILTER
  SAVED_SEGMENT
  EVENT_PARTICIPANTS
  EVENT_TEAMS
  UPLOADED_CSV
  MANUAL_SELECTION
  SYSTEM
}

enum EmailBroadcastEventType {
  CREATED
  UPDATED
  AUDIENCE_ESTIMATED
  RECIPIENT_SNAPSHOT_CREATED
  SCHEDULED
  QUEUED
  SENDING_STARTED
  RECIPIENT_QUEUED
  RECIPIENT_SENT
  RECIPIENT_FAILED
  RECIPIENT_SKIPPED
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  UNSUBSCRIBED
  CANCELLED
  FINISHED
  TEST_SENT
}

enum EmailWebhookProcessingStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum AuditAction {
  WORKSPACE_CREATED
  WORKSPACE_UPDATED
  WORKSPACE_ARCHIVED
  WORKSPACE_RESTORED
  WORKSPACE_PARENT_CHANGED

  WORKSPACE_MEMBER_ADDED
  WORKSPACE_MEMBER_UPDATED
  WORKSPACE_MEMBER_REMOVED

  WORKSPACE_ACCESS_POLICY_CREATED
  WORKSPACE_ACCESS_POLICY_UPDATED
  WORKSPACE_ACCESS_POLICY_REVOKED

  EVENT_STAFF_GRANT_CREATED
  EVENT_STAFF_GRANT_UPDATED
  EVENT_STAFF_GRANT_REVOKED
  EVENT_STAFF_ACCESS_RECALCULATED
  EVENT_OWNER_TRANSFERRED

  ORGANIZATION_MAP_VIEWED

  LEGACY_EVENT_ADMIN_MIGRATED
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique @db.Citext
  passwordHash String?
  name         String?

  // Name fields
  lastNameCyrillic   String?
  firstNameCyrillic  String?
  middleNameCyrillic String?
  lastNameLatin      String?
  firstNameLatin     String?
  middleNameLatin    String?
  hasNoLastName      Boolean @default(false)
  hasNoFirstName     Boolean @default(false)
  hasNoMiddleName    Boolean @default(false)
  fullNameCyrillic   String?
  fullNameLatin      String?

  bio                   String?
  city                  String?
  factualAddress        String?
  phone                 String?
  telegram              String?
  phoneVerifiedAt       DateTime?
  telegramVerifiedAt    DateTime?
  nativeLanguage        String?
  communicationLanguage String?
  consentPersonalData   Boolean   @default(false)
  consentPersonalDataAt DateTime?
  consentClientRules    Boolean   @default(false)
  consentClientRulesAt  DateTime?
  birthDate             DateTime?
  avatarUrl             String?
  avatarAssetId         String?
  role                  UserRole  @default(USER)
  isActive              Boolean   @default(true)
  emailVerifiedAt       DateTime?
  registeredAt          DateTime  @default(now())
  lastLoginAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  accounts                             UserAccount[]
  createdEvents                        Event[]                           @relation("CreatedBy")
  createdOrganizerWorkspaces           OrganizerWorkspace[]              @relation("OrganizerWorkspaceCreatedBy")
  organizerWorkspaceMemberships        OrganizerWorkspaceMember[]        @relation("OrganizerWorkspaceMemberUser")
  invitedOrganizerWorkspaceMemberships OrganizerWorkspaceMember[]        @relation("OrganizerWorkspaceMemberInvitedBy")
  workspaceEventAccessPolicies         WorkspaceEventAccessPolicy[]      @relation("WorkspaceEventAccessPolicyUser")
  createdWorkspaceEventAccessPolicies  WorkspaceEventAccessPolicy[]      @relation("WorkspaceEventAccessPolicyCreatedBy")
  revokedWorkspaceEventAccessPolicies  WorkspaceEventAccessPolicy[]      @relation("WorkspaceEventAccessPolicyRevokedBy")
  eventStaffGrants                     EventStaffGrant[]                 @relation("EventStaffGrantUser")
  assignedEventStaffGrants             EventStaffGrant[]                 @relation("EventStaffGrantAssignedBy")
  eventStaffAccesses                   EventStaffAccess[]                @relation("EventStaffAccessUser")
  auditLogsAuthored                    AuditLog[]                        @relation("AuditLogActor")
  auditLogsTargeting                   AuditLog[]                        @relation("AuditLogTargetUser")
  eventMemberships                     EventMember[]                     @relation("EventMemberUser")
  assignedEventMembers                 EventMember[]                     @relation("EventMemberAssignedBy")
  teamMemberships                      EventTeamMember[]
  captainedTeams                       EventTeam[]                       @relation("TeamCaptain")
  receivedTeamInvitations              EventTeamInvitation[]             @relation("TeamInvitationInvitee")
  sentTeamInvitations                  EventTeamInvitation[]             @relation("TeamInvitationInvitedBy")
  requestedTeamChanges                 EventTeamChangeRequest[]          @relation("TeamChangeRequestedBy")
  decidedTeamChanges                   EventTeamChangeRequest[]          @relation("TeamChangeDecidedBy")
  analyticsEvents                      AnalyticsEvent[]
  registrationSubmissions              EventRegistrationFormSubmission[]
  refreshSessions                      RefreshSession[]
  avatarAsset                          MediaAsset?                       @relation("UserAvatar", fields: [avatarAssetId], references: [id], onDelete: SetNull)
  profileSectionStates                 UserProfileSectionState[]
  extendedProfile                      UserExtendedProfile?
  identityDocument                     UserIdentityDocument?
  internationalPassport                UserInternationalPassport?
  socialLinks                          UserSocialLinks?
  activityDirections                   UserActivityDirection[]
  additionalLanguages                  UserAdditionalLanguage[]
  additionalDocuments                  UserAdditionalDocument[]
  emergencyContact                     UserEmergencyContact?
  mediaAssets                          MediaAsset[]                      @relation("MediaAssetOwner")

  supportThreads             SupportThread[]          @relation("SupportThreadUser")
  assignedSupportThreads     SupportThread[]          @relation("SupportThreadAdmin")
  supportMessages            SupportMessage[]         @relation("SupportMessageSender")
  supportReadStates          SupportThreadReadState[] @relation("SupportThreadReadStateUser")
  uploadedSupportAttachments SupportAttachment[]      @relation("SupportAttachmentUploader")

  passwordResetTokens           PasswordResetToken[]
  preferences                   UserPreference[]
  updatedProfileFieldVisibility ProfileFieldVisibilitySetting[] @relation("ProfileFieldVisibilityUpdatedBy")
  createdExportPresets          ExportPreset[]                  @relation("ExportPresetCreatedBy")
  createdReportTemplates        SystemReportTemplate[]          @relation("SystemReportTemplateCreatedBy")
  requestedReportRuns           SystemReportRun[]               @relation("SystemReportRunRequestedBy")
  emailMessages                 EmailMessage[]                  @relation("EmailMessageUser")
  createdEmailTemplates         EmailTemplate[]                 @relation("EmailTemplateCreatedBy")
  updatedEmailTemplates         EmailTemplate[]                 @relation("EmailTemplateUpdatedBy")
  createdEmailBroadcasts        EmailBroadcast[]                @relation("EmailBroadcastCreatedBy")
  emailBroadcastRecipients      EmailBroadcastRecipient[]
  emailBroadcastEvents          EmailBroadcastEvent[]           @relation("EmailBroadcastEventActor")
  communicationConsents         UserCommunicationConsent[]
  createdEmailAudiences         EmailAudience[]                 @relation("EmailAudienceCreatedBy")

  @@map("users")
}

model UserProfileSectionState {
  id         String               @id @default(cuid())
  userId     String
  sectionKey String
  status     ProfileSectionStatus @default(NOT_STARTED)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sectionKey])
  @@index([userId])
  @@map("user_profile_section_states")
}

model UserExtendedProfile {
  userId                 String          @id
  gender                 Gender?
  citizenshipCountryCode String?
  residenceCountryCode   String?
  regionId               String?
  districtId             String?
  settlementId           String?
  regionText             String?
  districtText           String?
  settlementText         String?
  street                 String?
  house                  String?
  apartment              String?
  postalCode             String?
  consentMailing         Boolean         @default(false)
  consentMailingAt       DateTime?
  activityStatus         ActivityStatus?
  studiesInRussia        Boolean         @default(false)
  organizationName       String?
  facultyOrDepartment    String?
  classCourseYear        String?
  positionTitle          String?
  achievementsText       String?         @db.Text
  englishLevel           LanguageLevel?
  russianLevel           LanguageLevel?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  region     ReferenceUzRegion?     @relation(fields: [regionId], references: [id], onDelete: SetNull)
  district   ReferenceUzDistrict?   @relation(fields: [districtId], references: [id], onDelete: SetNull)
  settlement ReferenceUzSettlement? @relation(fields: [settlementId], references: [id], onDelete: SetNull)

  @@map("user_extended_profiles")
}

model UserIdentityDocument {
  id                           String                @id @default(cuid())
  userId                       String                @unique
  documentType                 IdentityDocumentType?
  citizenshipCountryCode       String?
  documentSeries               String?
  documentNumber               String?
  issueDate                    DateTime?
  issuedBy                     String?
  issueCountryCode             String?
  expiryDate                   DateTime?
  placeOfBirth                 String?
  pinfl                        String?
  passportSeries               String?
  passportNumber               String?
  subdivisionCode              String?
  snils                        String?
  hasSecondCitizenship         Boolean               @default(false)
  secondCitizenshipCountryCode String?
  scanAssetId                  String?               @unique
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  scanAsset MediaAsset? @relation("IdentityDocumentScan", fields: [scanAssetId], references: [id], onDelete: SetNull)

  @@map("user_identity_documents")
}

model UserInternationalPassport {
  id          String    @id @default(cuid())
  userId      String    @unique
  countryCode String?
  series      String?
  number      String?
  issueDate   DateTime?
  expiryDate  DateTime?
  issuedBy    String?
  scanAssetId String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  scanAsset MediaAsset? @relation("InternationalPassportScan", fields: [scanAssetId], references: [id], onDelete: SetNull)

  @@map("user_international_passports")
}

model UserSocialLinks {
  userId          String   @id
  maxUrl          String?
  maxAbsent       Boolean  @default(false)
  vkUrl           String?
  vkAbsent        Boolean  @default(false)
  telegramUrl     String?
  telegramAbsent  Boolean  @default(false)
  instagramUrl    String?
  instagramAbsent Boolean  @default(false)
  facebookUrl     String?
  facebookAbsent  Boolean  @default(false)
  xUrl            String?
  xAbsent         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_social_links")
}

model UserActivityDirection {
  id        String            @id @default(cuid())
  userId    String
  direction ActivityDirection
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, direction])
  @@index([userId])
  @@map("user_activity_directions")
}

model UserAdditionalLanguage {
  id           String   @id @default(cuid())
  userId       String
  languageName String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, languageName])
  @@index([userId])
  @@map("user_additional_languages")
}

model UserAdditionalDocument {
  id        String                 @id @default(cuid())
  userId    String
  type      AdditionalDocumentType
  assetId   String                 @unique
  notes     String?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset MediaAsset @relation("UserAdditionalDocumentAsset", fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("user_additional_documents")
}

model UserEmergencyContact {
  id           String   @id @default(cuid())
  userId       String   @unique
  fullName     String?
  relationship String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_emergency_contacts")
}

model ReferenceCountry {
  code      String   @id
  nameRu    String
  nameEn    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reference_countries")
}

model ReferenceUzRegion {
  id        String  @id @default(cuid())
  code      String  @unique
  nameRu    String
  nameEn    String
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  districts ReferenceUzDistrict[]
  profiles  UserExtendedProfile[]

  @@map("reference_uz_regions")
}

model ReferenceUzDistrict {
  id        String  @id @default(cuid())
  regionId  String
  code      String  @unique
  nameRu    String
  nameEn    String
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  region      ReferenceUzRegion       @relation(fields: [regionId], references: [id], onDelete: Cascade)
  settlements ReferenceUzSettlement[]
  profiles    UserExtendedProfile[]

  @@index([regionId])
  @@map("reference_uz_districts")
}

model ReferenceUzSettlement {
  id         String  @id @default(cuid())
  districtId String
  code       String  @unique
  nameRu     String
  nameEn     String
  type       String?
  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)

  district ReferenceUzDistrict   @relation(fields: [districtId], references: [id], onDelete: Cascade)
  profiles UserExtendedProfile[]

  @@index([districtId])
  @@map("reference_uz_settlements")
}

model MediaAsset {
  id               String            @id @default(cuid())
  ownerUserId      String
  purpose          MediaAssetPurpose
  status           MediaAssetStatus  @default(ACTIVE)
  originalFilename String
  mimeType         String
  sizeBytes        Int
  storageDriver    String
  storageKey       String
  publicUrl        String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  ownerUser                    User                       @relation("MediaAssetOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  avatarForUsers               User[]                     @relation("UserAvatar")
  identityDocumentScanFor      UserIdentityDocument?      @relation("IdentityDocumentScan")
  internationalPassportScanFor UserInternationalPassport? @relation("InternationalPassportScan")
  userAdditionalDocumentFor    UserAdditionalDocument?    @relation("UserAdditionalDocumentAsset")

  @@index([ownerUserId, purpose, status])
  @@map("media_assets")
}

model UserAccount {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  providerEmail     String?      @db.Citext
  providerUsername  String?
  providerAvatarUrl String?
  linkedAt          DateTime     @default(now())
  lastUsedAt        DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("user_accounts")
}

model RegistrationVerification {
  id                       String    @id @default(cuid())
  email                    String    @unique @db.Citext
  codeHash                 String
  codeSentAt               DateTime
  codeExpiresAt            DateTime
  verifiedAt               DateTime?
  completionTokenHash      String?
  completionTokenExpiresAt DateTime?
  attempts                 Int       @default(0)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([codeExpiresAt])
  @@index([completionTokenExpiresAt])
  @@map("registration_verifications")
}

model OrganizerWorkspace {
  id          String                   @id @default(cuid())
  name        String
  slug        String                   @unique
  description String?
  kind        OrganizerWorkspaceKind   @default(DEPARTMENT)
  status      OrganizerWorkspaceStatus @default(ACTIVE)

  parentId String?
  parent   OrganizerWorkspace?  @relation("WorkspaceTree", fields: [parentId], references: [id], onDelete: SetNull)
  children OrganizerWorkspace[] @relation("WorkspaceTree")

  createdById String?
  createdBy   User?   @relation("OrganizerWorkspaceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  members  OrganizerWorkspaceMember[]
  policies WorkspaceEventAccessPolicy[]
  events   Event[]

  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  @@index([parentId])
  @@index([kind, status])
  @@index([status])
  @@map("organizer_workspaces")
}

model OrganizerWorkspaceMember {
  id          String                @id @default(cuid())
  workspaceId String
  userId      String
  role        OrganizerMemberRole
  status      OrganizerMemberStatus @default(ACTIVE)

  invitedByUserId String?
  invitedAt       DateTime?
  joinedAt        DateTime?
  removedAt       DateTime?

  workspace OrganizerWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User               @relation("OrganizerWorkspaceMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?              @relation("OrganizerWorkspaceMemberInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, userId])
  @@index([userId, status])
  @@index([workspaceId, role, status])
  @@map("organizer_workspace_members")
}

model Event {
  id               String  @id @default(cuid())
  slug             String  @unique
  title            String
  shortDescription String
  fullDescription  String  @db.Text
  coverImageUrl    String?
  category         String
  location         String

  // Registration and limits
  capacity           Int @default(100)
  registrationsCount Int @default(0)

  // Timing
  startsAt             DateTime
  endsAt               DateTime
  registrationOpensAt  DateTime?
  registrationDeadline DateTime?

  // Registration Settings
  registrationEnabled          Boolean          @default(true)
  registrationMode             RegistrationMode @default(INDIVIDUAL)
  volunteerApplicationsEnabled Boolean          @default(false)
  requiredProfileFields        String[]         @default([])
  requiredEventFields          String[]         @default([])
  customRegistrationFields     Json?
  conditions                   String?
  contactEmail                 String?
  contactPhone                 String?
  tags                         String[]
  status                       EventStatus      @default(DRAFT)
  isFeatured                   Boolean          @default(false)

  // Team settings
  isTeamBased                  Boolean      @default(false)
  minTeamSize                  Int          @default(1)
  maxTeamSize                  Int          @default(1)
  allowSoloParticipation       Boolean      @default(true)
  teamJoinMode                 TeamJoinMode @default(OPEN)
  requireAdminApprovalForTeams Boolean      @default(false)

  // Individual participation config
  requireParticipantApproval Boolean                    @default(false)
  participantLimitMode       ParticipantLimitMode       @default(UNLIMITED)
  participantTarget          Int?
  participantCountVisibility ParticipantCountVisibility @default(PUBLIC)

  publishedAt          DateTime?
  createdById          String?
  organizerWorkspaceId String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  createdBy               User?                             @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  organizerWorkspace      OrganizerWorkspace?               @relation(fields: [organizerWorkspaceId], references: [id], onDelete: SetNull)
  members                 EventMember[]
  staffGrants             EventStaffGrant[]
  staffAccesses           EventStaffAccess[]
  teams                   EventTeam[]
  teamInvitations         EventTeamInvitation[]
  analyticsEvents         AnalyticsEvent[]
  registrationSubmissions EventRegistrationFormSubmission[]
  milestones              EventMilestone[]
  exportPresets           ExportPreset[]

  @@index([organizerWorkspaceId])
  @@map("events")
}

model EventRegistrationFormSubmission {
  id          String   @id @default(cuid())
  eventId     String
  userId      String
  answersJson Json
  isComplete  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
  @@map("event_registration_form_submissions")
}

model EventMember {
