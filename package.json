{
  "name": "event-platform-mvp",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@event-platform/web --filter=@event-platform/api",
    "dev:web": "turbo run dev --filter=@event-platform/web",
    "dev:api": "turbo run dev --filter=@event-platform/api",

    "build": "turbo run build",
    "build:web": "turbo run build --filter=@event-platform/web",
    "build:api": "turbo run build --filter=@event-platform/api",

    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",

    "clean": "turbo run clean && node -e \"const fs=require('fs'); ['node_modules','.turbo'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}))\"",

    "db:generate": "pnpm --filter @event-platform/api prisma generate",
    "db:migrate": "pnpm --filter @event-platform/api prisma migrate dev",
    "db:push": "pnpm --filter @event-platform/api prisma db push",
    "db:seed": "pnpm --filter @event-platform/api prisma db seed",
    "db:studio": "pnpm --filter @event-platform/api prisma studio",

    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "@swc/core",
      "argon2",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "turbo": "2.9.6",
    "typescript": "6.0.2"
  }
}
