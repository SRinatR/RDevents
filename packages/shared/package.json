{
  "name": "@event-platform/shared",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*",
      "default": "./dist/*"
    }
  },
  "scripts": {
    "dev": "node -e \"console.log('shared package: nothing to run')\"",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "node -e \"const fs=require('fs'); ['dist','node_modules','.tsbuildinfo'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}))\""
  },
  "devDependencies": {
    "typescript": "6.0.2"
  }
}
