{
  "name": "@event-platform/shared",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "dev": "node -e \"console.log('shared package: nothing to run')\"",
    "build": "node -e \"console.log('shared package: no separate build yet')\"",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "node -e \"const fs=require('fs'); ['node_modules'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}))\""
  },
  "devDependencies": {
    "typescript": "6.0.2"
  }
}
