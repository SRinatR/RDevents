{
  "name": "@event-platform/ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "dev": "node -e \"console.log('ui package: nothing to run')\"",
    "build": "node -e \"console.log('ui package: no separate build yet')\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "node -e \"const fs=require('fs'); ['node_modules'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}))\""
  },
  "peerDependencies": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "typescript": "6.0.2"
  }
}
